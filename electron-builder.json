{
  "appId": "com.pawprint.app",
  "productName": "爪印",
  "directories": {
    "output": "dist/build"
  },
  "files": [
    "dist/renderer/**/*",
    "build/**/*",
    "electron-main.js",
    "electron-preload.js",
    "node_modules/**/*"
  ],
  "win": {
    "target": "nsis",
    "icon": "build/icon.ico",
    "signAndEditExecutable": false
  },
  "nsis": {
    "oneClick": false,
    "allowElevation": true,
    "allowToChangeInstallationDirectory": true,
    "installerIcon": "build/icon.ico",
    "uninstallerIcon": "build/icon.ico",
    "installerHeaderIcon": "build/icon.ico",
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "爪印"
  }
}
